/**
 * 疫苗接种列表 — 温润极简
 */
.container { padding: var(--space-md); min-height: 100vh; padding-bottom: 120rpx; }
.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-md); }
.title { font-size: var(--font-2xl); font-weight: 800; }
.add-btn { font-size: var(--font-md); color: var(--color-primary); padding: var(--space-xs) var(--space-md); background: var(--color-primary-light); border-radius: var(--radius-full); }
.item { display: flex; justify-content: space-between; align-items: center; background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); margin-bottom: var(--space-sm); box-shadow: var(--shadow-sm); }
.item-body { flex: 1; display: flex; justify-content: space-between; align-items: center; }
.item-left { display: flex; flex-direction: column; gap: 4rpx; }
.item-type { font-size: var(--font-md); font-weight: 600; color: var(--text-primary); }
.item-date { font-size: var(--font-xs); color: var(--text-secondary); }
.item-right { display: flex; align-items: center; }
.item-status { font-size: var(--font-sm); font-weight: 600; padding: 4rpx 18rpx; border-radius: var(--radius-full); }
.item-status.completed { color: #4CAF50; background: rgba(76,175,80,0.1); }
.item-status.upcoming { color: #FF8C42; background: rgba(255,140,66,0.1); }
.item-status.skipped { color: #999; background: rgba(0,0,0,0.05); }
.delete-btn { font-size: 32rpx; color: var(--color-primary); padding: var(--space-xs) var(--space-sm); }
.delete-btn:active { transform: scale(0.85); }
.empty { text-align: center; padding: var(--space-2xl) 0; color: var(--text-tertiary); font-size: var(--font-md); }
