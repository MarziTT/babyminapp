<view class="container">
  <view class="header">
    <text class="title">{{mode === 'edit' ? '编辑接种记录' : '添加接种记录'}}</text>
  </view>

  <view class="input-group">
    <text class="input-label">疫苗名称</text>
    <picker mode="selector" range="{{vaccineOptions}}" bindchange="onVaccineSelect">
      <view class="form-picker">{{vaccineName || '请选择疫苗名称'}}</view>
    </picker>
  </view>

  <view class="input-group" wx:if="{{showCustomInput}}">
    <text class="input-label">自定义名称</text>
    <input class="form-input" placeholder="请输入疫苗名称" value="{{customVaccineName}}" bindinput="onCustomNameInput"/>
  </view>

  <view class="input-group">
    <text class="input-label">状态</text>
    <picker mode="selector" range="{{statusOptions}}" bindchange="onStatusSelect">
      <view class="form-picker">{{status === 'completed' ? '已完成' : '待接种'}}</view>
    </picker>
  </view>

  <view class="input-group">
    <text class="input-label">计划日期</text>
    <picker mode="date" value="{{scheduledDate}}" bindchange="onDateChange">
      <view class="form-picker">{{scheduledDate}}</view>
    </picker>
  </view>

  <view class="input-group">
    <text class="input-label">备注</text>
    <textarea class="note-input" placeholder="选填：接种地点、注意事项等" value="{{note}}" bindinput="onNoteInput" maxlength="200"/>
  </view>

  <button class="submit-btn" bindtap="onSubmit">保存记录</button>
</view>
