/**
 * 添加用药记录 — 温润极简
 */
.container { padding: var(--space-md); min-height: 100vh; padding-bottom: 120rpx; }
.header { margin-bottom: var(--space-lg); }
.title { font-size: var(--font-2xl); font-weight: 800; }
.input-group { margin-bottom: var(--space-lg); }
.input-label { font-size: var(--font-sm); color: var(--text-secondary); font-weight: 600; display: block; margin-bottom: var(--space-sm); }
.form-input { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-lg); box-shadow: var(--shadow-sm); }
.form-picker { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-md); color: var(--color-primary); box-shadow: var(--shadow-sm); display: flex; align-items: center; }
.metric-row { display: flex; gap: var(--space-md); margin-bottom: var(--space-lg); }
.metric-item { flex: 1; }
.metric-item .input-label { font-size: var(--font-sm); margin-bottom: var(--space-sm); }
.note-input { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-md); min-height: 140rpx; box-shadow: var(--shadow-sm); }
.submit-btn { width: 100%; height: 96rpx; background: var(--color-primary); color: var(--text-inverse); font-size: var(--font-lg); font-weight: 700; border-radius: var(--radius-full); margin-top: var(--space-xl); border: none; box-shadow: 0 8rpx 24rpx rgba(212,120,107,0.3); }
.submit-btn:active { background: var(--color-primary-dark); transform: scale(0.97); }
.submit-btn[disabled] { background: var(--color-border); color: var(--text-tertiary); box-shadow: none; }
