/**
 * 智能助手页 — 对话流样式（柔和蓝色系）
 */

/* ===== 页面级：禁止页面滚动 ===== */
page {
  height: 100vh;
  overflow: hidden;
}

/* ===== 容器 ===== */
/* 覆盖 app.wxss 全局 .container 的 padding/min-height */
.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #F5F7FA;
  padding: 0;
  min-height: 0;
}

/* ===== 消息列表 ===== */
.chat-list {
  flex: 1;
  overflow: hidden;
  box-sizing: border-box;
}

.chat-list-inner {
  padding: 24rpx 24rpx 0;
}

.chat-spacer {
  height: 24rpx;
}

/* ===== 消息行 ===== */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-ai {
  justify-content: flex-start;
}

.msg-user {
  justify-content: flex-end;
}

/* ===== 头像 ===== */
.msg-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-ai {
  background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.avatar-user {
  background: #D1D5DB;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.avatar-text {
  font-size: 36rpx;
  line-height: 1;
}

/* ===== 气泡 ===== */
.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
  margin: 0 16rpx;
}

.bubble-ai {
  background: #FFFFFF;
  color: #333;
  margin-left: 16rpx;
  margin-right: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.bubble-user {
  background: #E3F0FF;
  color: #333;
  margin-left: 0;
  margin-right: 16rpx;
}

.msg-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
}

/* ===== 打字动画 ===== */
.typing .typing-dot {
  display: inline-block;
  animation: blink 1.4s infinite both;
  font-size: 12rpx;
  margin: 0 2rpx;
  color: #999;
}

.typing .typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing .typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes blink {
  0%, 80%, 100% { opacity: 0.3; }
  40% { opacity: 1; }
}

/* ===== 确认卡片 ===== */
.confirm-card {
  margin: 0 24rpx 24rpx;
  margin-left: calc(80rpx + 16rpx + 16rpx);
  padding: 24rpx;
  background: #FFF;
  border-radius: 12rpx;
  border: 1rpx solid #E8ECF1;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.card-fields .field-row {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  gap: 12rpx;
}

.field-label {
  font-size: 26rpx;
  color: #8894A3;
  width: 80rpx;
  flex-shrink: 0;
}

.field-text {
  font-size: 26rpx;
  color: #8894A3;
}

.field-input {
  flex: 1;
  height: 60rpx;
  padding: 0 12rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #E8ECF1;
}

.field-input-short {
  width: 120rpx;
  height: 60rpx;
  padding: 0 12rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #E8ECF1;
}

.field-input-note {
  flex: 1;
  height: 60rpx;
  padding: 0 12rpx;
  background: #F5F7FA;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #E8ECF1;
}

.field-unit {
  font-size: 24rpx;
  color: #8894A3;
  width: 60rpx;
  flex-shrink: 0;
}

.side-options {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.side-opt {
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  background: #F5F7FA;
  border: 1rpx solid #E8ECF1;
}

.side-opt-active {
  color: #FFF;
  background: #667EEA;
  border-color: #667EEA;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 72rpx;
}

.btn-cancel {
  background: #F5F7FA;
  color: #8894A3;
}

.btn-confirm {
  background: #667EEA;
  color: #FFF;
}

.btn-confirm[disabled] {
  background: #D1D5DB;
  color: #FFF;
}

/* ===== 已确认标记 ===== */
.confirm-done {
  margin: 0 24rpx 24rpx;
  margin-left: calc(80rpx + 16rpx + 16rpx);
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.done-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #52C41A;
  color: #FFF;
  font-size: 24rpx;
  font-weight: 700;
}

.done-text {
  font-size: 26rpx;
  color: #52C41A;
  font-weight: 500;
}

.confirm-done.cancelled .done-icon {
  background: #8894A3;
}

.confirm-done.cancelled .done-text {
  color: #8894A3;
}

/* ===== 折叠展开 ===== */
.expand-row {
  display: flex;
  gap: 40rpx;
  padding: 10rpx 0 0;
}

.expand-link {
  font-size: 24rpx;
  color: #667EEA;
  padding: 8rpx 0;
}

.expand-link:active {
  opacity: 0.6;
}

/* ===== 预设按钮 ===== */
.preset-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 4rpx 0 12rpx;
  margin-left: 88rpx;
}

.preset-btn {
  font-size: 24rpx;
  color: #666;
  background: #F5F7FA;
  border: 1rpx solid #E8ECF1;
  border-radius: 24rpx;
  padding: 6rpx 18rpx;
}

.preset-btn:active {
  opacity: 0.7;
}

.preset-active {
  color: #FFF;
  background: #667EEA;
  border-color: #667EEA;
}

/* ===== 输入栏 ===== */
.input-bar {
  flex-shrink: 0;
  background: #FFF;
  padding: 20rpx 0 16rpx 0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-inner {
  padding: 0 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 660rpx;
  margin: 0 auto;
}

.text-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  background: #F5F7FA;
  border-radius: 38rpx;
  font-size: 28rpx;
  color: #333;
}

.text-input::placeholder {
  color: #A8B2BF;
}

/* ===== 麦克风按钮 ===== */
.voice-btn {
  flex-shrink: 0;
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E8ECF1;
  transition: all 0.15s ease;
}

.voice-btn:active {
  background: #E3E8F0;
  transform: scale(0.95);
}

.voice-btn-active {
  background: #667EEA;
  border-color: #667EEA;
  animation: voicePulse 1.2s ease-in-out infinite;
}

.voice-btn-active .voice-icon,
.voice-btn-cancel .voice-icon {
  filter: brightness(0) invert(1);
}

.voice-btn-cancel {
  background: #E74C3C;
  border-color: #E74C3C;
  animation: none;
}

.voice-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 录音脉冲动画 */
@keyframes voicePulse {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(102, 126, 234, 0.5);
  }
  50% {
    box-shadow: 0 0 0 16rpx rgba(102, 126, 234, 0);
  }
}

/* ===== 录音状态提示 ===== */
.recording-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 12rpx;
}

.recording-wave {
  font-size: 24rpx;
  color: #667EEA;
  letter-spacing: 4rpx;
  min-height: 32rpx;
  line-height: 32rpx;
}

.recording-text {
  font-size: 22rpx;
  color: #8894A3;
  margin-top: 4rpx;
}

.send-btn {
  flex-shrink: 0;
  width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #667EEA;
  color: #FFF;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 72rpx;
}

.send-btn[disabled] {
  background: #D1D5DB;
  color: #FFF;
}
