/* 快捷计时器 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #EEF2FB 0%, #F5F7FA 60%);
  padding-bottom: 40rpx;
}

/* ========== 计时显示区 ========== */
.timer-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.timer-ring-wrap {
  position: relative;
  width: 340rpx;
  height: 340rpx;
  margin-bottom: 48rpx;
}

/* 背景圆环 */
.ring-bg {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 10rpx solid #E8ECF2;
}

/* 进度圆环 - 右半圆 */
.ring-progress {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 10rpx solid transparent;
  border-top-color: #D4785C;
  border-right-color: #D4785C;
  transition: transform 0.5s ease;
  opacity: 0;
}

.ring-progress.running {
  opacity: 1;
  border-top-color: #D4785C;
  border-right-color: #D4785C;
  animation: ringPulse 2s ease-in-out infinite;
}

.ring-progress.finished {
  opacity: 1;
  border-top-color: #52C41A;
  border-right-color: #52C41A;
  animation: none;
}

@keyframes ringPulse {
  0%, 100% { border-top-color: #D4785C; border-right-color: #D4785C; }
  50% { border-top-color: #E8957F; border-right-color: #E8957F; }
}

/* 内圆 */
.timer-inner {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  border-radius: 50%;
  background: #FFFFFF;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.06);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.timer-min,
.timer-sec {
  font-size: 80rpx;
  font-weight: 200;
  color: #2C3E50;
  font-family: 'SF Mono', 'Menlo', monospace;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}
.timer-colon {
  font-size: 56rpx;
  font-weight: 200;
  color: #BDC3C7;
  margin: 0 4rpx;
  line-height: 1;
}
.timer-row {
  display: flex;
  align-items: baseline;
}
.timer-hint {
  font-size: 22rpx;
  color: #B0B8C4;
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ========== 控制按钮 ========== */
.timer-controls {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  padding: 0 40rpx;
  line-height: 88rpx;
}
.ctrl-btn::after { border: none; }

.ctrl-icon {
  font-size: 28rpx;
}

.ctrl-start {
  background: linear-gradient(135deg, #D4785C, #C15B3D);
  color: #FFFFFF;
  box-shadow: 0 6rpx 24rpx rgba(193, 91, 61, 0.3);
}

.ctrl-pause {
  background: linear-gradient(135deg, #FFA726, #F57C00);
  color: #FFFFFF;
  box-shadow: 0 6rpx 24rpx rgba(245, 124, 0, 0.25);
}

.ctrl-reset {
  background: #F0F0F5;
  color: #7F8C9B;
}

.ctrl-finish {
  background: linear-gradient(135deg, #52C41A, #389E0D);
  color: #FFFFFF;
  box-shadow: 0 6rpx 24rpx rgba(82, 196, 26, 0.3);
}

/* ========== 预设选择 ========== */
.presets-section {
  padding: 0 32rpx;
  margin-top: 8rpx;
}

.section-label {
  font-size: 26rpx;
  color: #8D99A8;
  margin-bottom: 20rpx;
  display: block;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.presets-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.preset-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 0 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.preset-item:active {
  transform: scale(0.96);
}

.preset-item.active {
  border-color: #D4785C;
  background: linear-gradient(180deg, #FFF5F2, #FFEFEA);
  box-shadow: 0 4rpx 20rpx rgba(212, 120, 92, 0.15);
}

.preset-num {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #2C3E50;
  line-height: 1.1;
}
.preset-unit {
  display: block;
  font-size: 22rpx;
  color: #A0AAB4;
  margin-top: 6rpx;
}

.preset-item.active .preset-num { color: #C15B3D; }
.preset-item.active .preset-unit { color: #C15B3D; }

/* ========== 自定义输入 ========== */
.custom-input {
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.number-input {
  flex: 1;
  font-size: 32rpx;
  color: #2C3E50;
  height: 56rpx;
}

.input-unit {
  font-size: 26rpx;
  color: #A0AAB4;
  margin-left: 12rpx;
}

/* ========== 保存表单 ========== */
.save-section {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

.save-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
}

.save-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2C3E50;
  display: block;
  margin-bottom: 28rpx;
  text-align: center;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #7F8C9B;
  display: block;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F7F8FA;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #2C3E50;
  box-sizing: border-box;
}

.form-summary {
  background: #F0F5FF;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 28rpx 0 24rpx;
  text-align: center;
}

.summary-text {
  font-size: 26rpx;
  color: #7F8C9B;
}

.summary-highlight {
  font-weight: 700;
  color: #D4785C;
  font-size: 30rpx;
}

.save-actions {
  display: flex;
  gap: 16rpx;
}

.btn-save {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #D4785C, #C15B3D);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
  border: none;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(193, 91, 61, 0.25);
}

.btn-save::after { border: none; }

.btn-skip {
  width: 160rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: #F0F0F5;
  color: #8D99A8;
  font-size: 26rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
  padding: 0;
}

.btn-skip::after { border: none; }

/* ========== 底部安全区 ========== */
.bottom-safe {
  height: 40rpx;
}
