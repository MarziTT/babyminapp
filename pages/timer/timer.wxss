/* 涂药计时器 */

.page { padding: 0 0 100rpx; min-height: 100vh; background: #F9F5F2; }

/* 计时显示 */
.timer-display {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 0 48rpx;
}

.timer-ring {
  width: 320rpx; height: 320rpx; border-radius: 160rpx;
  background: #fff; display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(212,120,92,0.1);
  border: 8rpx solid #E8DDD5;
  transition: border-color 0.3s;
  margin-bottom: 48rpx;
}
.timer-ring.running { border-color: #D4785C; animation: pulse-ring 2s infinite; }
.timer-ring.finished { border-color: #4CAF50; }

@keyframes pulse-ring {
  0%, 100% { box-shadow: 0 8rpx 40rpx rgba(212,120,92,0.1); }
  50% { box-shadow: 0 8rpx 60rpx rgba(212,120,92,0.2); }
}

.timer-min, .timer-sec {
  font-size: 80rpx; font-weight: 300; color: #333; font-variant-numeric: tabular-nums;
}
.timer-colon { font-size: 64rpx; font-weight: 300; color: #999; margin: 0 4rpx; }

/* 控制按钮 */
.timer-controls { display: flex; gap: 24rpx; }
.btn-start {
  width: 240rpx; height: 88rpx; border-radius: 44rpx; background: linear-gradient(135deg, #D4785C, #C15B3D);
  color: #fff; font-size: 32rpx; font-weight: 600; line-height: 88rpx; text-align: center;
  border: none; padding: 0; box-shadow: 0 6rpx 24rpx rgba(193,91,61,0.3);
}
.btn-pause {
  width: 180rpx; height: 88rpx; border-radius: 44rpx; background: #FFA726;
  color: #fff; font-size: 30rpx; font-weight: 600; line-height: 88rpx; text-align: center;
  border: none; padding: 0; box-shadow: 0 4rpx 16rpx rgba(255,167,38,0.3);
}
.btn-reset {
  width: 140rpx; height: 88rpx; border-radius: 44rpx; background: #eee;
  color: #666; font-size: 28rpx; font-weight: 500; line-height: 88rpx; text-align: center;
  border: none; padding: 0;
}

/* 预设选择 */
.presets-section { padding: 0 32rpx; }
.section-label { font-size: 26rpx; color: #999; margin-bottom: 16rpx; display: block; }

.presets-grid { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.preset-item {
  flex: 1; background: #fff; border-radius: 20rpx; padding: 24rpx 0;
  text-align: center; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent; transition: all 0.2s;
}
.preset-item.active { border-color: #D4785C; background: #FDF3EF; }
.preset-num { display: block; font-size: 40rpx; font-weight: 700; color: #333; }
.preset-unit { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.preset-item.active .preset-num { color: #C15B3D; }
.preset-item.active .preset-unit { color: #C15B3D; }

/* 自定义输入 */
.custom-input { margin-bottom: 16rpx; }
.input-row { display: flex; align-items: center; background: #fff; border-radius: 20rpx; padding: 20rpx 24rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.number-input { flex: 1; font-size: 32rpx; color: #333; height: 56rpx; }
.input-unit { font-size: 26rpx; color: #999; margin-left: 12rpx; }

/* 保存表单 */
.save-section { margin: 0 32rpx 0; }
.card { background: #fff; border-radius: 24rpx; padding: 32rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06); }
.form-group { margin-bottom: 24rpx; }
.form-label { font-size: 26rpx; color: #666; display: block; margin-bottom: 10rpx; }
.form-input {
  width: 100%; height: 80rpx; background: #F9F5F2; border-radius: 16rpx;
  padding: 0 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box;
}
.form-group.dim { opacity: 0.5; }
.form-value { font-size: 26rpx; color: #999; }

.save-actions { display: flex; gap: 16rpx; margin-top: 32rpx; }
.btn-save {
  flex: 1; height: 80rpx; border-radius: 16rpx; background: linear-gradient(135deg, #D4785C, #C15B3D);
  color: #fff; font-size: 28rpx; font-weight: 600; line-height: 80rpx; text-align: center;
  border: none; padding: 0;
}
.btn-skip {
  width: 160rpx; height: 80rpx; border-radius: 16rpx; background: #f5f5f5;
  color: #999; font-size: 26rpx; line-height: 80rpx; text-align: center;
  border: none; padding: 0;
}

.bottom-spacer { height: 40rpx; }
