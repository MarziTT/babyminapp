<!-- 快捷计时器 -->
<view class="page">

  <!-- 计时显示区 -->
  <view class="timer-display">
    <view class="timer-ring-wrap">
      <!-- 外圈进度环 -->
      <view class="ring-bg"></view>
      <view class="ring-progress {{isRunning ? 'running' : ''}} {{isFinished ? 'finished' : ''}}" style="transform: rotate({{ringDeg}}deg); opacity: {{ringOpacity}};"></view>
      <!-- 内圆时间显示 -->
      <view class="timer-inner">
        <view class="timer-row">
          <text class="timer-min">{{minDisplay}}</text>
          <text class="timer-colon">:</text>
          <text class="timer-sec">{{secDisplay}}</text>
        </view>
        <text class="timer-hint" wx:if="{{!isRunning && !isPaused && !isFinished}}">选择时长后开始</text>
        <text class="timer-hint" wx:elif="{{isRunning}}">计时中</text>
        <text class="timer-hint" wx:elif="{{isPaused}}">已暂停</text>
        <text class="timer-hint" wx:elif="{{isFinished}}">已完成</text>
      </view>
    </view>

    <!-- 控制按钮 -->
    <view class="timer-controls">
      <block wx:if="{{!isRunning && !isPaused && !isFinished}}">
        <button class="ctrl-btn ctrl-start" bindtap="startTimer" disabled="{{remaining <= 0}}">
          <text class="ctrl-icon">▶</text>
          <text>开始</text>
        </button>
      </block>
      <block wx:elif="{{isRunning}}">
        <button class="ctrl-btn ctrl-pause" bindtap="pauseTimer">
          <text class="ctrl-icon">⏸</text>
          <text>暂停</text>
        </button>
        <button class="ctrl-btn ctrl-reset" bindtap="resetTimer">
          <text class="ctrl-icon">↺</text>
          <text>重置</text>
        </button>
      </block>
      <block wx:elif="{{isPaused}}">
        <button class="ctrl-btn ctrl-start" bindtap="resumeTimer">
          <text class="ctrl-icon">▶</text>
          <text>继续</text>
        </button>
        <button class="ctrl-btn ctrl-reset" bindtap="resetTimer">
          <text class="ctrl-icon">↺</text>
          <text>重置</text>
        </button>
      </block>
      <block wx:elif="{{isFinished}}">
        <button class="ctrl-btn ctrl-finish" bindtap="resetTimer">
          <text class="ctrl-icon">↺</text>
          <text>重新开始</text>
        </button>
      </block>
    </view>
  </view>

  <!-- 预设时长 -->
  <view class="presets-section" wx:if="{{!isRunning && !isPaused}}">
    <text class="section-label">快速选择</text>
    <view class="presets-grid">
      <view class="preset-item {{selectedPreset === index ? 'active' : ''}}"
        wx:for="{{presets}}" wx:key="index"
        bindtap="selectPreset" data-index="{{index}}" data-minutes="{{item}}">
        <text class="preset-num">{{item}}</text>
        <text class="preset-unit">分钟</text>
      </view>
    </view>

    <view class="custom-input">
      <text class="section-label">自定义时长</text>
      <view class="input-row">
        <input class="number-input" type="number" placeholder="输入分钟数" value="{{customMinutes}}" bindinput="onCustomInput" />
        <text class="input-unit">分钟</text>
      </view>
    </view>
  </view>

  <!-- 计时完成后的保存表单 -->
  <view wx:if="{{isFinished && showSaveForm}}" class="save-section">
    <view class="save-card">
      <text class="save-title">记录涂药信息</text>
      <view class="form-group">
        <text class="form-label">药膏名称</text>
        <input class="form-input" placeholder="如：氧化锌软膏" value="{{medicineName}}" bindinput="onMedicineInput" />
      </view>
      <view class="form-group">
        <text class="form-label">涂药部位</text>
        <input class="form-input" placeholder="如：臀部" value="{{bodyArea}}" bindinput="onAreaInput" />
      </view>
      <view class="form-summary">
        <text class="summary-text">本次护理 <text class="summary-highlight">{{duration}}</text> 秒（约 {{duration / 60}} 分钟）</text>
      </view>
      <view class="save-actions">
        <button class="btn-save" bindtap="saveRecord">保存到用药记录</button>
        <button class="btn-skip" bindtap="skipSave">跳过</button>
      </view>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
