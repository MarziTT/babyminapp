.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #4F8CFF, #7CB3FF);
  padding: 60rpx 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.app-name {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 24rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.login-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.login-btn {
  width: 560rpx;
  height: 96rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  border: none;
}

.login-btn::after {
  border: none;
}

.login-btn[disabled] {
  background: rgba(255, 255, 255, 0.6);
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #4F8CFF;
}

.login-error {
  font-size: 26rpx;
  color: #FFE0E0;
  margin-top: 24rpx;
}

/* 分割线 */
.login-divider {
  display: flex;
  align-items: center;
  width: 560rpx;
  margin-top: 48rpx;
  margin-bottom: 36rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: rgba(255, 255, 255, 0.3);
}

.divider-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  margin: 0 24rpx;
}

/* 体验模式按钮 */
.demo-btn {
  width: 560rpx;
  padding: 24rpx 0;
  background: rgba(255, 255, 255, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.demo-btn::after {
  border: none;
}

.demo-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.demo-btn-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

.login-footer {
  position: absolute;
  bottom: 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}
