<view class="container">
  <view class="header">
    <text class="title">成长记录</text>
    <text class="add-btn" bindtap="goAdd">+ 添加</text>
  </view>

  <view class="chart-toggle" bindtap="toggleChart">
    <text class="chart-toggle-text">数据图表</text>
    <text class="chart-toggle-arrow">{{showChart ? '▲' : '▼'}}</text>
  </view>

  <view class="chart-container" wx:if="{{showChart}}">
    <view class="chart-tabs">
      <view class="chart-tab {{chartType === 'height' ? 'active' : ''}}" data-type="height" bindtap="switchChart">身高曲线</view>
      <view class="chart-tab {{chartType === 'weight' ? 'active' : ''}}" data-type="weight" bindtap="switchChart">体重曲线</view>
    </view>
    <view class="chart-gender" wx:if="{{showChart}}">
      <view class="gender-tag {{gender === 'boy' ? 'active' : ''}}" bindtap="switchGender" data-gender="boy">👦 男宝</view>
      <view class="gender-tag {{gender === 'girl' ? 'active' : ''}}" bindtap="switchGender" data-gender="girl">👧 女宝</view>
    </view>
    <canvas type="2d" id="growthChart" style="width: 690rpx; height: 500rpx;"></canvas>
  </view>

  <view class="filter-row">
    <view class="filter-item">
      <text class="filter-label">从</text>
      <picker mode="date" value="{{dateFrom}}" bindchange="onDateFromChange">
        <text class="filter-value">{{dateFromDisplay}}</text>
      </picker>
    </view>
    <text class="filter-sep">~</text>
    <view class="filter-item">
      <text class="filter-label">至</text>
      <picker mode="date" value="{{dateTo}}" bindchange="onDateToChange">
        <text class="filter-value">{{dateToDisplay}}</text>
      </picker>
    </view>
  </view>

  <view class="list" wx:if="{{records.length > 0}}">
    <view class="item" wx:for="{{records}}" wx:key="id">
      <view class="item-body" bindtap="editRecord" data-id="{{item.id}}">
        <text class="item-date">{{item.displayTime}}</text>
        <view class="item-metrics">
          <view class="metric-group" wx:if="{{item.height_cm}}">
            <text class="item-metric">{{item.height_cm}}cm</text>
            <text class="item-delta positive" wx:if="{{item.heightDelta > 0}}">+{{item.heightDelta}}cm</text>
            <text class="item-delta negative" wx:elif="{{item.heightDelta < 0}}">{{item.heightDelta}}cm</text>
          </view>
          <view class="metric-group" wx:if="{{item.weight_kg}}">
            <text class="item-metric">{{item.weight_kg}}kg</text>
            <text class="item-delta positive" wx:if="{{item.weightDelta > 0}}">+{{item.weightDelta}}kg</text>
            <text class="item-delta negative" wx:elif="{{item.weightDelta < 0}}">{{item.weightDelta}}kg</text>
          </view>
          <text class="item-metric" wx:if="{{item.head_circumference_cm}}">头围{{item.head_circumference_cm}}cm</text>
          <text class="item-note" wx:if="{{item.note}}">{{item.note}}</text>
          <text class="item-recorder" wx:if="{{item.recorded_by_name}}">{{item.recorded_by_name}}记录</text>
        </view>
      </view>
      <text class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">✕</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <text>暂无成长记录</text>
  </view>
</view>
