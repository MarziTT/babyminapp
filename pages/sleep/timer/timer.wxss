/**
 * 睡眠计时器 — 星空暗夜主题
 */
.page {
  width: 100vw; min-height: 100vh;
  background: linear-gradient(180deg, #0F1B33 0%, #1B2A4A 30%, #2D3A5C 70%, #1A2744 100%);
  display: flex; flex-direction: column; align-items: center;
  overflow: hidden; position: relative;
}

/* 星空 */
.stars { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
.star {
  position: absolute;
  width: 4rpx; height: 4rpx;
  background: #FFFFFF;
  border-radius: 50%;
  opacity: 0;
  animation: twinkle 2s ease-in-out infinite;
}
@keyframes twinkle {
  0%, 100% { opacity: 0; transform: scale(0.8); }
  50% { opacity: 0.8; transform: scale(1.3); }
}

/* 月亮 */
.moon {
  position: absolute; top: 80rpx; right: 60rpx;
  width: 120rpx; height: 120rpx;
  background: radial-gradient(circle at 40% 40%, #FFFDE7, #FFF9C4 40%, #FFE082 100%);
  border-radius: 50%;
  box-shadow: 0 0 60rpx rgba(255,253,231,0.4), 0 0 120rpx rgba(255,253,231,0.15);
}

/* 返回按钮 */
.back-btn { position: absolute; top: 60rpx; left: 40rpx; z-index: 10; }
.back-arrow { font-size: 40rpx; color: rgba(255,255,255,0.7); padding: 16rpx; }

/* 标题 */
.title-area { margin-top: 200rpx; text-align: center; z-index: 2; }
.main-title { font-size: 44rpx; font-weight: 700; color: #E8EAF6; display: block; }
.sub-title { font-size: 26rpx; color: rgba(232,234,246,0.5); margin-top: 16rpx; display: block; }

/* 计时器圆盘 */
.timer-ring {
  margin-top: 120rpx;
  width: 440rpx; height: 440rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
  border: 6rpx solid rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
  transition: all 0.4s ease;
}
.timer-ring.active {
  border-color: rgba(129,199,245,0.5);
  box-shadow: 0 0 80rpx rgba(129,199,245,0.2), inset 0 0 60rpx rgba(129,199,245,0.05);
  animation: breathe 2s ease-in-out infinite;
}
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.timer-inner {
  width: 380rpx; height: 380rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 45%, rgba(26,39,68,0.9), rgba(15,27,51,0.95));
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}

.timer-display {
  font-size: 80rpx; font-weight: 200;
  color: #E8EAF6;
  font-variant-numeric: tabular-nums;
  letter-spacing: 6rpx;
  font-family: -apple-system, 'Helvetica Neue', sans-serif;
}

.timer-hint {
  font-size: 24rpx; color: rgba(232,234,246,0.35);
  margin-top: 12rpx;
}

/* 底部提示 */
.footer-hint { position: absolute; bottom: 120rpx; z-index: 2; }
.footer-hint text { font-size: 22rpx; color: rgba(232,234,246,0.25); }
