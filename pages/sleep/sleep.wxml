<view class="container">
  <view class="header">
    <text class="title">睡眠记录</text>
    <view class="header-actions">
      <text class="add-btn" bindtap="goAdd">+ 添加</text>
    </view>
  </view>

  <view class="date-switcher">
    <text class="date-arrow" bindtap="prevDay">◀</text>
    <picker mode="date" value="{{targetDate}}" end="{{targetDate}}" bindchange="onDateChange">
      <text class="date-text">{{dateDisplay}}</text>
    </picker>
    <text class="date-arrow" bindtap="nextDay">▶</text>
  </view>

  <!-- 实时记录入口 -->
  <view class="realtime-btn" bindtap="goTimer">
    <text class="realtime-icon">⏱</text>
    <text class="realtime-label">实时记录</text>
    <text class="realtime-sub">点击开始计时宝宝睡眠</text>
  </view>

  <view class="list" wx:if="{{records.length > 0}}">
    <view class="item" wx:for="{{records}}" wx:key="id">
      <view class="item-body" bindtap="editRecord" data-id="{{item.id}}">
        <view class="item-left">
          <text class="item-time">{{item.displayTime}}</text>
          <text class="item-duration">{{item.duration_minutes}} 分钟</text>
        </view>
        <view class="item-right">
          <text class="item-note" wx:if="{{item.note}}">{{item.note}}</text>
          <text class="item-empty" wx:else>-</text>
          <text class="item-recorder" wx:if="{{item.recorded_by_name}}">{{item.recorded_by_name}}记录</text>
        </view>
      </view>
      <text class="delete-btn" catchtap="deleteRecord" data-id="{{item.id}}">✕</text>
    </view>
  </view>

  <view class="empty" wx:else>
    <text>暂无睡眠记录</text>
  </view>
</view>
