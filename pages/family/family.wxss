/* ==========================================
   家庭页样式 — 品牌蓝 #4F8CFF 温暖视觉
   ========================================== */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F5FF 0%, #F5F7FA 30%);
  padding: 24rpx;
}

/* ========== 加载 ========== */
.loading-area {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}
.empty-icon-wrap {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  background: linear-gradient(135deg, #E8F0FF 0%, #D0E0FF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}
.empty-icon-large {
  font-size: 80rpx;
}
.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.6;
  padding: 0 40rpx;
}
.empty-logout {
  margin-top: 32rpx;
}
.empty-actions {
  display: flex;
  gap: 24rpx;
}
.action-btn {
  width: 260rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  background: #FFFFFF;
  color: #4F8CFF;
  border: 2rpx solid #4F8CFF;
  box-shadow: 0 4rpx 16rpx rgba(79,140,255,0.1);
}
.action-btn.primary {
  background: linear-gradient(135deg, #4F8CFF, #6EA3FF);
  color: #FFFFFF;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(79,140,255,0.3);
}
.action-btn::after {
  border: none;
}

/* ========== 宝宝信息卡片 ========== */
.baby-card {
  position: relative;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4F8CFF 0%, #6DA3FF 50%, #8FBCFF 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(79,140,255,0.35);
  overflow: hidden;
  animation: cardFadeIn 0.6s ease-out;
}
.baby-card-bg {
  position: absolute;
  top: -40rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 100rpx;
  background: rgba(255,255,255,0.08);
  pointer-events: none;
}
@keyframes cardFadeIn {
  from { opacity: 0; transform: translateY(-12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.baby-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  border: 4rpx solid rgba(255,255,255,0.55);
  margin-right: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}
.baby-avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}
.placeholder-emoji {
  font-size: 48rpx;
}
.baby-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.baby-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}
.baby-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 12rpx;
}
.baby-birthday {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}
.baby-age-tag {
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.baby-age-tag text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 分区卡片 ========== */
.section {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

/* ========== 家庭成员列表 ========== */
.member-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.member-item {
  display: flex;
  align-items: center;
  padding: 14rpx 8rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}
.member-item:active {
  background: #F5F7FA;
}
.member-avatar-wrap {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  border: 3rpx solid #E8F0FF;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.member-avatar-placeholder-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #F0F4FF;
  border: 3rpx solid #E8F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.member-online-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 9rpx;
  background: #52C41A;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 0 6rpx rgba(82,196,26,0.4);
}
.member-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}
.member-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.3;
}
.member-role {
  font-size: 22rpx;
  color: #AAA;
}
.member-badge {
  font-size: 20rpx;
  color: #4F8CFF;
  background: #F0F4FF;
  padding: 4rpx 14rpx;
  border-radius: 14rpx;
  font-weight: 500;
  flex-shrink: 0;
}

/* ========== 家庭码 — 邀请卡 ========== */
.invite-section .section-title {
  margin-bottom: 16rpx;
}
.invite-card {
  background: linear-gradient(135deg, #F0F5FF 0%, #E8F0FF 100%);
  border-radius: 20rpx;
  border: 2rpx solid #D0E0FF;
  overflow: hidden;
}
.invite-card-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx 24rpx;
}
.invite-label {
  font-size: 24rpx;
  color: #7F9FD6;
  margin-bottom: 12rpx;
}
.invite-code {
  font-size: 48rpx;
  font-weight: 800;
  color: #4F8CFF;
  font-family: 'Courier New', monospace;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(79,140,255,0.15);
}
.invite-card-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #C8D8F8, transparent);
  margin: 0 32rpx;
}
.invite-card-bottom {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 24rpx 28rpx;
}
.invite-desc {
  font-size: 26rpx;
  color: #5A7DB5;
  font-weight: 500;
}
.invite-desc-sub {
  font-size: 22rpx;
  color: #8EADC8;
  margin-top: 6rpx;
}
.invite-copy-btn {
  margin-top: 20rpx;
  width: 260rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, #4F8CFF, #6EA3FF);
  border-radius: 36rpx;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(79,140,255,0.25);
}
.invite-copy-btn::after {
  border: none;
}

/* ========== 加入链接 ========== */
.join-link {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
}
.join-link-text {
  font-size: 28rpx;
  color: #4F8CFF;
  font-weight: 500;
}
.join-link-arrow {
  font-size: 32rpx;
  color: #4F8CFF;
  margin-left: 6rpx;
}

/* ========== 退出登录按钮 ========== */
.logout-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 480rpx;
  height: 80rpx;
  border: 2rpx solid #FF6B6B;
  border-radius: 40rpx;
  background: rgba(255, 107, 107, 0.06);
  margin: 0 auto;
}
.logout-link-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF6B6B;
}

/* ========== 弹窗统一 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-card {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.15);
}
.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}
.form-input {
  height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
}
.form-picker {
  height: 80rpx;
  line-height: 80rpx;
  background: #F5F7FA;
  border-radius: 16rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #666;
}
.role-row {
  display: flex;
  gap: 20rpx;
}
.role-tag {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #F5F7FA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.role-tag.active {
  background: #F0F4FF;
  color: #4F8CFF;
  border: 2rpx solid #4F8CFF;
  font-weight: 600;
}
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}
.btn-cancel,
.btn-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}
.btn-cancel {
  background: #F5F7FA;
  color: #666;
}
.btn-cancel::after { border: none; }
.btn-confirm {
  background: linear-gradient(135deg, #4F8CFF, #6EA3FF);
  color: #FFFFFF;
  box-shadow: 0 6rpx 20rpx rgba(79,140,255,0.25);
}
.btn-confirm::after { border: none; }

/* ========== 头像上传 ========== */
.avatar-upload {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 3rpx solid #E8F0FF;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.avatar-preview-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #F5F7FA;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border: 3rpx dashed #DDD;
}
.avatar-hint {
  font-size: 22rpx;
  color: #4F8CFF;
  margin-top: 12rpx;
}

/* ========== 宝宝管理卡片列表 ========== */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-header .section-title {
  margin-bottom: 0;
}
.section-add {
  font-size: 26rpx;
  color: #4F8CFF;
  font-weight: 600;
}
.baby-card-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.baby-card-item {
  width: calc(50% - 10rpx);
}
.baby-card-inner {
  background: #FAFBFF;
  border-radius: 20rpx;
  border: 2rpx solid #EEF2FB;
  padding: 28rpx 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.baby-card-item:only-child {
  width: 100%;
}
.baby-card-item:only-child .baby-card-inner {
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}
.baby-card-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  border: 4rpx solid #E8F0FF;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 16rpx;
}
.baby-card-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 40rpx;
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
}
.baby-male {
  background: linear-gradient(135deg, #5BA0F5, #3D7FD9);
}
.baby-female {
  background: linear-gradient(135deg, #F5A0B0, #E07085);
}
.baby-card-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 4rpx;
}
.baby-card-birth {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 2rpx;
}
.baby-card-gender {
  font-size: 22rpx;
  color: #AAA;
  margin-bottom: 14rpx;
}
.baby-card-actions {
  display: flex;
  gap: 24rpx;
}
.baby-card-edit {
  font-size: 24rpx;
  color: #4F8CFF;
  padding: 6rpx 20rpx;
  background: #F0F4FF;
  border-radius: 20rpx;
  font-weight: 500;
}
.baby-card-del {
  font-size: 24rpx;
  color: #FF4D4F;
  padding: 6rpx 20rpx;
  background: #FFF1F0;
  border-radius: 20rpx;
  font-weight: 500;
}
.empty-hint {
  width: 100%;
  text-align: center;
  font-size: 24rpx;
  color: #CCC;
  padding: 40rpx 0;
}

/* ========== 底部安全区 ========== */
.bottom-safe {
  height: 40rpx;
}
