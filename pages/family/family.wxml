<view class="container">
  <!-- 加载中 -->
  <view class="loading-area" wx:if="{{loading}}">
    <text class="loading-text">加载中…</text>
  </view>

  <!-- 无家庭状态 -->
  <view class="empty-state" wx:elif="{{!hasFamily}}">
    <text class="empty-icon">👨‍👩‍👧</text>
    <text class="empty-title">你还未加入任何家庭</text>
    <text class="empty-desc">创建或加入一个家庭，与家人一起记录宝宝成长</text>
    <view class="empty-actions">
      <button class="action-btn primary" bindtap="onShowCreate">创建家庭</button>
      <button class="action-btn" bindtap="onShowJoin">加入家庭</button>
    </view>
  </view>

  <!-- 有家庭 -->
  <block wx:else>
    <!-- 宝宝信息卡片 -->
    <view class="baby-card">
      <image wx:if="{{babyAvatar}}" class="baby-avatar" src="{{babyAvatar}}" mode="aspectFill" />
      <view wx:else class="baby-avatar-placeholder">
        <text class="placeholder-emoji">👶</text>
      </view>
      <view class="baby-info">
        <text class="baby-name">{{babyName}}</text>
        <text class="baby-birthday" wx:if="{{babyBirthday}}">出生: {{babyBirthday}}</text>
      </view>
    </view>

    <!-- 家庭成员 -->
    <view class="section">
      <text class="section-title">家庭成员 ({{members.length}}人)</text>
      <view class="member-list">
        <view class="member-item"
          wx:for="{{members}}"
          wx:key="openid"
          data-openid="{{item.openid}}"
          data-role="{{item.role}}"
          data-nickname="{{item.nickname}}"
          bindtap="onMemberAvatarTap"
          bindlongpress="onMemberLongPress"
        >
          <image wx:if="{{item.avatar_url}}" class="member-avatar" src="{{item.avatar_url}}" mode="aspectFill" />
          <view wx:else class="member-avatar-placeholder-sm">
            <text>{{item.role === 'mom' ? '👩' : item.role === 'dad' ? '👨' : '👤'}}</text>
          </view>
          <view class="member-info">
            <text class="member-name">{{item.nickname || '未命名'}}</text>
            <text class="member-role">{{item.role === 'mom' ? '妈妈' : item.role === 'dad' ? '爸爸' : item.role === 'admin' ? '管理员' : item.role === 'editor' ? '编辑者' : '查看者'}}</text>
          </view>
          <text class="member-perm-tag" wx:if="{{item.role !== 'mom' && item.role !== 'dad'}}">{{item.role === 'admin' ? '管理员' : item.role === 'editor' ? '编辑' : '查看'}}</text>
          <text class="member-badge" wx:if="{{item.role === myRole || item.openid === openid}}">我</text>
        </view>
      </view>
    </view>

    <!-- 宝宝管理 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">我的宝宝 ({{babies.length}})</text>
        <text class="section-add" bindtap="onShowBabyForm">+ 添加</text>
      </view>
      <view class="baby-mgmt-list">
        <view class="baby-mgmt-item" wx:for="{{babies}}" wx:key="id">
          <image wx:if="{{item.avatar}}" class="baby-mgmt-avatar" src="{{item.avatar}}" mode="aspectFill" />
          <view wx:else class="baby-mgmt-placeholder {{item.gender === 'male' ? 'baby-male' : 'baby-female'}}">
            <text>{{item.name ? item.name.charAt(0) : '宝'}}</text>
          </view>
          <view class="baby-mgmt-info">
            <text class="baby-mgmt-name">{{item.name || '宝宝'}}</text>
            <text class="baby-mgmt-birth">{{item.birthday || '未设生日'}}</text>
            <text class="baby-mgmt-gender">{{item.gender === 'male' ? '♂ 男宝' : '♀ 女宝'}}</text>
          </view>
          <view class="baby-mgmt-actions">
            <text class="baby-mgmt-edit" data-id="{{item.id}}" bindtap="onShowBabyForm">编辑</text>
            <text class="baby-mgmt-del" data-id="{{item.id}}" bindtap="onDeleteBaby">删除</text>
          </view>
        </view>
        <view wx:if="{{babies.length === 0}}" class="empty-hint">还没有宝宝，点击上方「+ 添加」</view>
      </view>
    </view>

    <!-- 家庭码 -->
    <view class="section">
      <text class="section-title">我的家庭码</text>
      <view class="code-card">
        <text class="code-text">{{familyId}}</text>
        <button class="copy-btn" bindtap="onCopyCode">复制</button>
      </view>
      <text class="code-hint">将家庭码分享给家人，对方可凭此码加入家庭</text>
    </view>

    <!-- 加入其他家庭 -->
    <view class="section">
      <view class="join-link" bindtap="onShowJoin">
        <text class="join-link-text">加入其他家庭</text>
        <text class="join-link-arrow">›</text>
      </view>
    </view>
  </block>

  <!-- ========== 创建家庭弹窗 ========== -->
  <view class="modal-overlay" wx:if="{{showCreate}}" bindtap="onHideCreate">
    <view class="modal-card" catchtap="catchTap">
      <text class="modal-title">创建家庭</text>
      <view class="form-group">
        <text class="form-label">宝宝昵称</text>
        <input class="form-input" placeholder="宝宝" value="{{inputBabyName}}" bindinput="onBabyNameInput" />
      </view>
      <view class="form-group">
        <text class="form-label">出生日期</text>
        <picker mode="date" value="{{inputBirthday}}" bindchange="onBirthdayChange">
          <view class="form-picker">{{inputBirthday || '选填'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">我是</text>
        <view class="role-row">
          <view class="role-tag {{inputRole === 'mom' ? 'active' : ''}}" bindtap="onSelectCreateRole" data-role="mom">👩 妈妈</view>
          <view class="role-tag {{inputRole === 'dad' ? 'active' : ''}}" bindtap="onSelectCreateRole" data-role="dad">👨 爸爸</view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="onHideCreate">取消</button>
        <button class="btn-confirm" bindtap="onCreateFamily">创建</button>
      </view>
    </view>
  </view>

  <!-- ========== 加入家庭弹窗 ========== -->
  <view class="modal-overlay" wx:if="{{showJoin}}" bindtap="onHideJoin">
    <view class="modal-card" catchtap="catchTap">
      <text class="modal-title">加入家庭</text>
      <view class="form-group">
        <text class="form-label">家庭码</text>
        <input class="form-input" placeholder="例如 fam-xxxxxxxx" value="{{inputFamilyId}}" bindinput="onFamilyIdInput" maxlength="12" />
      </view>
      <view class="form-group">
        <text class="form-label">我是</text>
        <view class="role-row">
          <view class="role-tag {{inputJoinRole === 'mom' ? 'active' : ''}}" bindtap="onSelectJoinRole" data-role="mom">👩 妈妈</view>
          <view class="role-tag {{inputJoinRole === 'dad' ? 'active' : ''}}" bindtap="onSelectJoinRole" data-role="dad">👨 爸爸</view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="onHideJoin">取消</button>
        <button class="btn-confirm" bindtap="onJoinFamily">加入</button>
      </view>
    </view>
  </view>

  <!-- ========== 宝宝表单弹窗 ========== -->
  <view class="modal-overlay" wx:if="{{showBabyForm}}" bindtap="onHideBabyForm">
    <view class="modal-card" catchtap="catchTap">
      <text class="modal-title">{{editBaby ? '编辑宝宝' : '添加宝宝'}}</text>
      <view class="form-group">
        <text class="form-label">头像</text>
        <view class="avatar-upload" bindtap="onBabyFormAvatarTap">
          <image wx:if="{{babyFormAvatar}}" class="avatar-preview" src="{{babyFormAvatar}}" mode="aspectFill" />
          <view wx:else class="avatar-preview-placeholder">📷</view>
          <text class="avatar-hint">点击上传</text>
        </view>
      </view>
      <view class="form-group">
        <text class="form-label">宝宝昵称</text>
        <input class="form-input" placeholder="宝宝" value="{{babyFormName}}" bindinput="onBabyFormNameInput" />
      </view>
      <view class="form-group">
        <text class="form-label">出生日期</text>
        <picker mode="date" value="{{babyFormBirthday}}" bindchange="onBabyFormBirthdayChange">
          <view class="form-picker">{{babyFormBirthday || '选填'}}</view>
        </picker>
      </view>
      <view class="form-group">
        <text class="form-label">性别</text>
        <view class="role-row">
          <view class="role-tag {{babyFormGender === 'male' ? 'active' : ''}}" bindtap="onBabyFormGenderTap" data-gender="male">♂ 男宝</view>
          <view class="role-tag {{babyFormGender === 'female' ? 'active' : ''}}" bindtap="onBabyFormGenderTap" data-gender="female">♀ 女宝</view>
        </view>
      </view>
      <view class="modal-actions">
        <button class="btn-cancel" bindtap="onHideBabyForm">取消</button>
        <button class="btn-confirm" bindtap="onSubmitBaby">{{editBaby ? '保存' : '添加'}}</button>
      </view>
    </view>
  </view>

  <view class="bottom-safe"></view>
</view>
