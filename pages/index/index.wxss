/* 首页样式 */

.page { padding: 0 0 80rpx; min-height: 100vh; }

/* 头部 */
.header {
  background: linear-gradient(135deg, #FF8C42 0%, #FFB347 100%);
  padding: 48rpx 48rpx 56rpx;
  border-radius: 0 0 40rpx 40rpx;
}
.header-top {
  display: flex; align-items: center; width: 100%;
}
.greeting { flex-shrink: 0; }
.greeting-text { display: block; font-size: 28rpx; color: rgba(255,255,255,0.75); }
.baby-name { display: block; font-size: 44rpx; font-weight: 700; color: #fff; margin-top: 4rpx; }
.header-actions { flex-shrink: 0; margin-left: auto; }
.header-avatar { width: 72rpx; height: 72rpx; border-radius: 36rpx; background: rgba(255,240,224,0.6); display: flex; align-items: center; justify-content: center; }
.avatar-img { width: 72rpx; height: 72rpx; border-radius: 36rpx; }
.avatar-placeholder { font-size: 40rpx; }

/* 提醒卡片 — 浮起白色卡片 */
.reminder-card {
  margin: -24rpx 28rpx 0;
  position: relative; z-index: 2;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: var(--color-surface);
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  display: flex; align-items: center;
}
.reminder-card-missing { border-left: 8rpx solid var(--color-warning); }
.reminder-card-done { border-left: 8rpx solid var(--color-accent); opacity: 0.8; }
.reminder-card-icon { font-size: 32rpx; margin-right: 14rpx; }
.reminder-card-text { flex: 1; font-size: 28rpx; color: #333; font-weight: 400; }
.reminder-card-arrow { font-size: 32rpx; color: #ccc; }

/* 无家庭提示 */
.no-family-tip {
  margin: 60rpx 32rpx; padding: 48rpx 40rpx;
  background: #FFF8F3; border-radius: 24rpx;
  text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 20rpx;
}
.no-family-text { font-size: 28rpx; color: #555; line-height: 1.6; }
.btn-link {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: transparent; border: 2rpx solid #FFD5C0;
  color: #FF8C42; font-size: 28rpx; font-weight: 500;
  border-radius: 40rpx; line-height: 1.4;
}

/* 今日概况 + 快速补录 双卡 */
.today-cards { display: flex; gap: 16rpx; padding: 24rpx 28rpx 0; }
.today-cards .card { margin-bottom: 0; box-shadow: none; }
.today-summary-card { flex: 2; padding: 24rpx; }
.today-summary-card .card-title { margin-bottom: 16rpx; color: #333; }
.card-title { font-size: 28rpx; font-weight: 500; color: #333; margin-bottom: 20rpx; }
.today-grid { display: flex; justify-content: space-around; }
.today-item { display: flex; flex-direction: column; align-items: center; padding: 8rpx 16rpx; flex: 1; }
.today-icon { font-size: 40rpx; margin-bottom: 8rpx; }
.today-count { font-size: 56rpx; font-weight: 600; color: #333; line-height: 1.1; }
.today-label { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.today-sub { font-size: 22rpx; color: #FF8C42; margin-top: 2rpx; }
.quick-log-card {
  flex: 1; padding: 24rpx;
  display: flex; flex-direction: column; justify-content: center;
  background: #fff;
  border: 2rpx solid #FFEEE5;
}
.quick-log-card .card-title { color: #FF8C42; }
.quick-log-inner { display: flex; flex-direction: column; align-items: center; }
.quick-log-icon { font-size: 52rpx; margin-bottom: 8rpx; }
.quick-log-hint { font-size: 22rpx; color: #999; }

/* 区块标题 */
.section-title { font-size: 28rpx; font-weight: 500; color: #333; padding: 36rpx 32rpx 20rpx; }

/* 快捷操作 — 统一网格 */
.quick-grid { padding: 0 28rpx; display: flex; flex-wrap: wrap; }
.qg-item {
  width: 33.33%; box-sizing: border-box;
  display: flex; flex-direction: column; align-items: center;
  padding: 28rpx 8rpx 24rpx;
}
.qg-icon-wrap {
  width: 88rpx; height: 88rpx; border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx;
}
.qg-icon { font-size: 40rpx; }
.qg-label { font-size: 26rpx; font-weight: 400; color: #333; margin-bottom: 4rpx; }
.qg-sub { font-size: 20rpx; color: #999; }


/* 最近记录 */
.recent-list { padding: 0 28rpx; }
.recent-item {
  display: flex; align-items: center; justify-content: space-between;
  background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 12rpx;
}
.recent-left { display: flex; align-items: center; flex: 1; overflow: hidden; }
.recent-type-icon { font-size: 36rpx; margin-right: 16rpx; }
.recent-info { overflow: hidden; }
.recent-type { display: block; font-size: 26rpx; font-weight: 400; color: #333; }
.recent-desc { display: block; font-size: 22rpx; color: #999; margin-top: 2rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.recent-time { font-size: 22rpx; color: #bbb; margin-left: 16rpx; flex-shrink: 0; }

/* 加载 */
.loading-state { padding: 80rpx; text-align: center; font-size: 26rpx; color: #999; }

.bottom-spacer { height: calc(40rpx + env(safe-area-inset-bottom)); }

/* ========== 宝宝切换器 ========== */
.baby-switcher {
  margin: 16rpx 28rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 16rpx 8rpx;
}
.baby-list {
  display: flex;
  white-space: nowrap;
}
.baby-tag {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
  padding: 8rpx 12rpx;
  margin: 0 4rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}
.baby-tag-active {
  background: var(--color-primary-light);
}
.baby-tag-avatar-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 6rpx;
}
.baby-tag-avatar {
  width: 64rpx;
  height: 64rpx;
}
.baby-tag-placeholder {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
}
.baby-male { background: linear-gradient(135deg, #4A90D9, #357ABD); }
.baby-female { background: linear-gradient(135deg, #F098A0, #E07080); }
.baby-tag-name {
  font-size: 22rpx;
  color: #555;
  max-width: 100rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.baby-tag-active .baby-tag-name {
  color: #C15B3D;
  font-weight: 500;
}
.baby-tag-add {
  justify-content: center;
}
.baby-tag-add-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  line-height: 64rpx;
}

/* ========== 家庭时间线 ========== */
.timeline {
  margin: 0 28rpx;
}
.timeline-item {
  display: flex;
  padding: 20rpx 0;
  position: relative;
}
.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 64rpx;
  flex-shrink: 0;
}
.timeline-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
}
.timeline-avatar-placeholder {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  background: #EEE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #999;
}
.timeline-line {
  width: 2rpx;
  flex: 1;
  background: #E8E8E8;
  min-height: 12rpx;
  margin-top: 6rpx;
}
.timeline-item:last-child .timeline-line {
  display: none;
}
.timeline-content {
  flex: 1;
  margin-left: 16rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.timeline-item:last-child .timeline-content {
  border-bottom: none;
}
.timeline-header {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}
.timeline-user {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-right: 8rpx;
}
.timeline-action {
  font-size: 24rpx;
  color: #777;
}
.timeline-detail {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.timeline-time {
  display: block;
  font-size: 22rpx;
  color: #BBB;
  margin-top: 6rpx;
}
.timeline-icon {
  font-size: 32rpx;
  margin-left: 12rpx;
  line-height: 48rpx;
  flex-shrink: 0;
}
