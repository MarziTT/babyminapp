<!-- AI 育儿顾问 -->
<view class="container">
  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="{{isSending ? 'typing-indicator' : 'msg-' + (messages.length - 1)}}">
    <view class="msg-item {{item.role}}" wx:for="{{messages}}" wx:key="index" id="msg-{{index}}">
      <text class="msg-avatar">{{item.role === 'user' ? '👨' : '🤖'}}</text>
      <view class="msg-bubble {{item.role}}">
        <text class="msg-text">{{item.content}}</text>
        <text class="msg-time">{{item.time}}</text>
      </view>
    </view>

    <view class="typing-indicator" wx:if="{{isSending}}" id="typing-indicator">
      <text class="dot">●</text><text class="dot">●</text><text class="dot">●</text>
    </view>
  </scroll-view>

  <!-- 快捷提问 -->
  <view class="quick-asks">
    <text class="quick-btn" bindtap="onQuickAsk" data-q="宝宝2个月大，一天应该喂几次？">2个月喂几次？</text>
    <text class="quick-btn" bindtap="onQuickAsk" data-q="宝宝夜里睡不踏实怎么办？">夜里睡不好？</text>
    <text class="quick-btn" bindtap="onQuickAsk" data-q="宝宝最近奶量减少了，正常吗？">奶量减少正常吗</text>
  </view>

  <!-- 输入框 -->
  <view class="input-bar">
    <input class="msg-input" value="{{inputValue}}" placeholder="输入育儿问题..." bindinput="onInput" confirm-type="send" bindconfirm="onSend"/>
    <button class="send-btn" bindtap="onSend" disabled="{{isSending}}">发送</button>
  </view>
</view>
