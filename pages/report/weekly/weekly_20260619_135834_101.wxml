<view class="container">
  <text class="page-title">每周育儿报告</text>

  <view class="loading-area" wx:if="{{loading}}">
    <text class="loading-text">正在分析本周数据…</text>
  </view>

  <view class="error-area" wx:elif="{{error}}">
    <text class="error-icon">😵</text>
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="loadReport">重试</button>
  </view>

  <!-- 空记录提示 -->
  <view class="empty-area" wx:elif="{{!hasRecords}}">
    <text class="empty-icon">📋</text>
    <text class="empty-title">暂无数据</text>
    <text class="empty-desc">{{report.message}}</text>
    <button class="retry-btn" bindtap="goRecord">去记录</button>
  </view>

  <!-- 报告内容 -->
  <view class="report-area" wx:else>
    <!-- 喂养 -->
    <view class="report-section">
      <text class="section-title">🍼 喂养</text>
      <view class="section-card">
        <view class="stat-row" wx:if="{{report.feeding_summary.daily_avg_count}}">
          <text class="stat-label">日均次数</text>
          <text class="stat-value">{{report.feeding_summary.daily_avg_count}} 次</text>
        </view>
        <view class="stat-row" wx:if="{{report.feeding_summary.daily_avg_ml}}">
          <text class="stat-label">日均奶量</text>
          <text class="stat-value">{{report.feeding_summary.daily_avg_ml}} ml</text>
        </view>
        <text class="trend-text">{{report.feeding_summary.trend}}</text>
      </view>
    </view>

    <!-- 睡眠 -->
    <view class="report-section">
      <text class="section-title">😴 睡眠</text>
      <view class="section-card">
        <view class="stat-row" wx:if="{{report.sleep_summary.daily_avg_hours}}">
          <text class="stat-label">日均睡眠</text>
          <text class="stat-value">{{report.sleep_summary.daily_avg_hours}} 小时</text>
        </view>
        <view class="stat-row" wx:if="{{report.sleep_summary.night_avg_hours}}">
          <text class="stat-label">夜间睡眠</text>
          <text class="stat-value">{{report.sleep_summary.night_avg_hours}} 小时</text>
        </view>
        <text class="trend-text">{{report.sleep_summary.trend}}</text>
      </view>
    </view>

    <!-- 尿布 -->
    <view class="report-section">
      <text class="section-title">🧷 尿布</text>
      <view class="section-card">
        <view class="stat-row" wx:if="{{report.diaper_summary.daily_avg_count}}">
          <text class="stat-label">日均次数</text>
          <text class="stat-value">{{report.diaper_summary.daily_avg_count}} 次</text>
        </view>
        <text class="trend-text">{{report.diaper_summary.trend}}</text>
      </view>
    </view>

    <!-- 建议 -->
    <view class="report-section" wx:if="{{report.suggestions && report.suggestions.length > 0}}">
      <text class="section-title">💡 AI 建议</text>
      <view class="suggestions-card">
        <view class="suggestion-item" wx:for="{{report.suggestions}}" wx:key="*this">
          <text class="suggestion-num">{{index + 1}}.</text>
          <text class="suggestion-text">{{item}}</text>
        </view>
      </view>
    </view>

    <view class="report-footer">
      <text class="report-tip">数据基于近 7 天记录，AI 分析仅供参考</text>
    </view>
  </view>
</view>
