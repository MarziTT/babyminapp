/**
 * 喂奶计时器 — 温暖亲喂主题
 */
.page {
  width: 100vw; min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F0 0%, #FDE8E4 30%, #FADADD 70%, #F8D5D0 100%);
  display: flex; flex-direction: column; align-items: center;
  overflow: hidden; position: relative;
}

/* 气泡装饰 */
.bubbles { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
.bubble {
  position: absolute;
  width: 20rpx; height: 20rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  animation: floatUp 4s ease-in-out infinite;
}
@keyframes floatUp {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
  50% { transform: translateY(-30rpx) scale(1.4); opacity: 0.6; }
}

/* 返回按钮 */
.back-btn { position: absolute; top: 60rpx; left: 40rpx; z-index: 10; }
.back-arrow { font-size: 40rpx; color: rgba(180,130,120,0.7); padding: 16rpx; }

/* 标题 */
.title-area { margin-top: 200rpx; text-align: center; z-index: 2; }
.main-title { font-size: 44rpx; font-weight: 700; color: #C4736A; display: block; }
.sub-title { font-size: 26rpx; color: rgba(180,130,120,0.6); margin-top: 16rpx; display: block; }

/* 计时器圆盘 */
.timer-ring {
  margin-top: 120rpx;
  width: 440rpx; height: 440rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 6rpx solid rgba(220,180,170,0.25);
  display: flex; align-items: center; justify-content: center;
  position: relative; z-index: 2;
  transition: all 0.4s ease;
}
.timer-ring.active {
  border-color: rgba(212,120,107,0.45);
  box-shadow: 0 0 80rpx rgba(212,120,107,0.18), inset 0 0 60rpx rgba(255,200,190,0.1);
  animation: breathe 2s ease-in-out infinite;
}
@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.02); }
}

.timer-inner {
  width: 380rpx; height: 380rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 45%, rgba(255,240,235,0.9), rgba(255,225,215,0.95));
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}

.timer-display {
  font-size: 80rpx; font-weight: 200;
  color: #C4736A;
  font-variant-numeric: tabular-nums;
  letter-spacing: 6rpx;
  font-family: -apple-system, 'Helvetica Neue', sans-serif;
}

.timer-hint {
  font-size: 24rpx; color: rgba(180,130,120,0.45);
  margin-top: 12rpx;
}

/* 底部提示 */
.footer-hint { position: absolute; bottom: 120rpx; z-index: 2; }
.footer-hint text { font-size: 22rpx; color: rgba(180,130,120,0.35); }