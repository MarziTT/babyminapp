<view class="page">
  <!-- 柔和暖色气泡装饰 -->
  <view class="bubbles">
    <view class="bubble" wx:for="{{8}}" wx:key="*this" style="left: {{item * 11 + 3}}%; top: {{item * 13 % 75 + 8}}%; animation-delay: {{item * 0.25}}s; animation-duration: {{3 + item * 0.5}}s;"></view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goBack">
    <text class="back-arrow">←</text>
  </view>

  <!-- 标题 -->
  <view class="title-area">
    <text class="main-title">🍼 喂奶计时</text>
    <text class="sub-title">{{isRunning ? '正在记录中...' : '点击开始计时宝宝喂奶'}}</text>
  </view>

  <!-- 计时器圆盘 -->
  <view class="timer-ring {{isRunning ? 'active' : ''}}" bindtap="toggleTimer">
    <view class="timer-inner">
      <text class="timer-display">{{timerDisplay}}</text>
      <text class="timer-hint">{{isRunning ? '轻触停止' : '开始计时'}}</text>
    </view>
  </view>

  <!-- 底部提示 -->
  <view class="footer-hint" wx:if="{{!isRunning}}">
    <text>停止后自动跳转保存记录</text>
  </view>
</view>