/**
 * 添加喂奶记录 — 温润极简
 */
.container { padding: var(--space-md); min-height: 100vh; padding-bottom: 120rpx; }

/* 实时计时入口 */
.timer-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  margin-bottom: var(--space-xl);
  background: linear-gradient(135deg, #FBE9E7, #FFF3E0);
  border-radius: var(--radius-lg);
  border: 2rpx dashed #E8B4B8;
}
.timer-entry-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.timer-entry-label { font-size: var(--font-lg); font-weight: 700; color: #D4786B; }
.timer-entry-sub { font-size: var(--font-xs); color: var(--text-tertiary); margin-top: 8rpx; }

.type-switch { display: flex; gap: var(--space-sm); margin-bottom: var(--space-xl); }
.type-item { flex: 1; text-align: center; padding: var(--space-md) 0; background: var(--color-surface); border-radius: var(--radius-lg); font-size: var(--font-md); color: var(--text-secondary); box-shadow: var(--shadow-sm); transition: all 0.25s; }
.type-item.active { background: var(--color-primary-light); color: var(--color-primary); font-weight: 700; box-shadow: 0 4rpx 16rpx rgba(212,120,107,0.15); }
.type-icon { font-size: 40rpx; display: block; margin-bottom: var(--space-xs); }

.submit-btn {
  margin-top: var(--space-xl);
  background: var(--color-primary);
  color: #FFF;
  border-radius: var(--radius-lg);
  font-size: var(--font-lg);
  font-weight: 700;
  padding: var(--space-md) 0;
  border: none;
}
.submit-btn::after { border: none; }

.picker-box { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-lg); box-shadow: var(--shadow-sm); margin-bottom: var(--space-sm); color: var(--text-primary); display: flex; align-items: center; }
.duration-hint { text-align: center; padding: var(--space-md); background: var(--color-accent-light); border-radius: var(--radius-md); margin-bottom: var(--space-lg); color: var(--color-accent); font-size: var(--font-md); font-weight: 600; }
.input-group { margin-bottom: var(--space-lg); }
.input-label { font-size: var(--font-sm); color: var(--text-secondary); font-weight: 600; display: block; margin-bottom: var(--space-sm); }
.amount-input { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-lg); box-shadow: var(--shadow-sm); }
.quick-amounts { display: flex; gap: 16rpx; margin-top: var(--space-sm); }
.quick-btn { flex: 1; text-align: center; padding: 10rpx 12rpx; min-width: 0; background: var(--color-bg); border-radius: var(--radius-md); font-size: var(--font-xs); color: var(--color-primary); font-weight: 500; }
.quick-btn:active { background: var(--color-primary-light); }
.note-input { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); font-size: var(--font-md); min-height: 140rpx; box-shadow: var(--shadow-sm); }

/* 备注模块 */
.note-section { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-md); box-shadow: var(--shadow-sm); margin-bottom: var(--space-lg); }
.note-section .input-label { font-size: var(--font-md); color: var(--text-primary); font-weight: 700; margin-bottom: var(--space-md); display: block; }
.note-chips { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-bottom: 0; }
.note-chip { padding: 14rpx 28rpx; border-radius: var(--radius-full); background: var(--color-bg); font-size: var(--font-sm); color: var(--text-secondary); border: 2rpx solid var(--color-border); transition: all 0.2s; }
.note-chip.active { background: var(--color-primary-light); color: var(--color-primary); border-color: var(--color-primary); font-weight: 600; }
.note-chip-custom { padding: 14rpx 28rpx; border-radius: var(--radius-full); background: transparent; font-size: var(--font-sm); color: var(--text-tertiary); border: 2rpx dashed var(--color-border); transition: all 0.2s; }
.note-chip-custom.active { color: var(--color-primary); border-color: var(--color-primary); border-style: solid; background: var(--color-primary-light); }
.custom-note-input { margin-top: var(--space-md); background: var(--color-bg); border-radius: var(--radius-md); padding: var(--space-md) var(--space-md); font-size: var(--font-md); width: 100%; box-sizing: border-box; border: 2rpx solid var(--color-border); color: var(--text-primary); min-height: 80rpx; line-height: 1.5; }
.submit-btn { width: 100%; height: 96rpx; background: var(--color-primary); color: var(--text-inverse); font-size: var(--font-lg); font-weight: 700; border-radius: var(--radius-full); margin-top: var(--space-xl); border: none; box-shadow: 0 8rpx 24rpx rgba(212,120,107,0.3); }
.submit-btn:active { background: var(--color-primary-dark); transform: scale(0.97); }
.submit-btn[disabled] { background: var(--color-border); color: var(--text-tertiary); box-shadow: none; }

/* 快速时长预设 */
.quick-durations { display: flex; flex-wrap: wrap; gap: 12rpx; justify-content: center; margin-top: var(--space-md); }
.quick-durations .quick-btn { flex: 0 0 auto; font-size: 22rpx; padding: 6rpx 16rpx; }
.quick-durations .quick-btn.active { background: var(--color-primary); color: var(--text-inverse); }
.custom-duration-input { margin-top: var(--space-sm); background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-sm) var(--space-md); font-size: var(--font-md); text-align: center; width: 200rpx; }
