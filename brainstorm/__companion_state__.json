" cy=\"25\" r=\"3\" fill=\"#fff\"/><rect x=\"18\" y=\"32\" width=\"12\" height=\"4\" rx=\"2\" fill=\"#fff\" opacity=\"0.5\"/><rect x=\"16\" y=\"4\" width=\"4\" height=\"10\" rx=\"2\" fill=\"#FF8C42\"/><rect x=\"28\" y=\"4\" width=\"4\" height=\"10\" rx=\"2\" fill=\"#FF8C42\"/></svg>\n      </div>\n      <div class=\"card-body\"><h3>机器人</h3><p>AI 的经典符号，识别度最高</p></div>\n    </div>\n    <div class=\"card\" data-choice=\"ai-brain\" onclick=\"toggleSelect(this)\">\n      <div class=\"card-image\" style=\"background:#FFF8F2; padding:24px; text-align:center\">\n        <svg width=\"48\" height=\"48\" viewBox=\"0 0 48 48\"><circle cx=\"24\" cy=\"24\" r=\"18\" fill=\"#FF8C42\"/><path d=\"M18 24c0-8 12-8 12 0\" stroke=\"#fff\" stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"/><path d=\"M16 20c0-6 8-10 16 0\" stroke=\"#fff\" stroke-width=\"2\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.5\"/><circle cx=\"20\" cy=\"32\" r=\"3\" fill=\"#fff\"/><circle cx=\"28\" cy=\"32\" r=\"3\" fill=\"#fff\"/></svg>\n      </div>\n      <div class=\"card-body\"><h3>智慧脑</h3><p>大脑造型 + 微笑，强调智能顾问属性</p></div>\n    </div>\n    <div class=\"card\" data-choice=\"ai-sparkle\" onclick=\"toggleSelect(this)\">\n      <div class=\"card-image\" style=\"background:#FFF8F2; padding:24px; text-align:center\">\n        <svg width=\"48\" height=\"48\" viewBox=\"0 0 48 48\"><circle cx=\"24\" cy=\"24\" r=\"16\" fill=\"#FF8C42\"/><path d=\"M24 4l2 8h-4l2-8zM24 44l-2-8h4l-2 8zM4 24l8 2v-4l-8 2zM44 24l-8-2v4l8-2zM10 10l6 6-3 3-6-6 3-3zM38 10l-6 6 3 3 6-6-3-3zM10 38l6-6-3-3-6 6 3 3zM38 38l-6-6 3-3 6 6-3 3z\" fill=\"#fff\" opacity=\"0.5\"/><circle cx=\"24\" cy=\"24\" r=\"6\" fill=\"#fff\"/></svg>\n      </div>\n      <div class=\"card-body\"><h3>星光</h3><p>闪亮星芒，传达 AI 的魔力与智慧</p></div>\n    </div>\n  </div>\n</div>\n\n<script>\ndocument.querySelectorAll('.card').forEach(card => {\n  card.addEventListener('click', function() {\n    const section = this.closest('.section');\n    const isMulti = section.queryS